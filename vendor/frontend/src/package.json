{
  "name": "matterbridge-template-frontend",
  "version": "1.0.0",
  "description": "Frontend for the matterbridge-template plugin",
  "author": "https://github.com/Luligu",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "oxlint --config .oxlintrc.json --max-warnings 0 --type-check --type-aware --report-unused-disable-directives-severity warn",
    "lint:fix": "oxlint --config .oxlintrc.json --max-warnings 0 --type-check --type-aware --report-unused-disable-directives-severity warn --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "clean": "node ../../scripts/clean.mjs",
    "deepClean": "node ../../scripts/deep-clean.mjs",
    "reset": "npm run deepClean && npm run softReset",
    "softReset": "npm install --no-fund --no-audit && npm prune --no-fund --no-audit && npm run build && npm run typecheck",
    "checkDependencies": "npm install --no-fund --no-audit --no-save npm-check-updates && ncu && npm run softReset",
    "updateDependencies": "npm install --no-fund --no-audit --no-save npm-check-updates && ncu -u && npm run softReset",
    "runMeBeforePublish": "npm run format && npm run lint && npm run build && npm run typecheck"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "9.2.0",
    "@mui/material": "9.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "7.0.2",
    "@vitejs/plugin-react": "6.0.3",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.25.0",
    "vite": "8.1.5"
  }
}
